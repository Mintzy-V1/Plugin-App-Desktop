{
  "name": "mintzy-plugin-desktop",
  "version": "1.0.0",
  "description": "Native Windows desktop wrapper for the Mintzy Plugin terminal",
  "main": "src/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev": "NODE_ENV=development electron .",
    "start": "electron .",
    "generate-icon": "node scripts/generate-icon.js",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && npm run generate-icon && electron-builder --win --x64",
    "build:dir": "npm run build:renderer && npm run generate-icon && electron-builder --win --x64 --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.mintzy.plugin-desktop",
    "productName": "Mintzy Plugin",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/main/**/*",
      "dist/renderer/**/*",
      "package.json",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mintzy Plugin",
      "artifactName": "${productName} Setup ${version}.${ext}"
    }
  },
  "author": "Mintzy V1",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.45.0",
    "axios": "^1.18.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2"
  }
}
